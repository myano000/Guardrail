{
  "testMethodMustAssert": {
    "testAttributes": [
      "Test", "TestCase", "TestCaseSource",
      "Theory", "InlineData", "Fact",
      "TestMethod", "DataTestMethod"
    ],
    "assertionTypeNames": [
      "Assert", "ClassicAssert",
      "StringAssert", "CollectionAssert",
      "Warn"
    ],
    "assertionMethodPatterns": [
      "Should"
    ]
  },
  "noRefOutParameter": {
    "allowedMethods": []
  },
  "constructorOnlyAssignments": {
    "allowedInvocations": []
  },
  "boolParameter": {
    "allowedMethods": ["That", "IsTrue", "IsFalse", "AreEqual"]
  },
  "noDowncast": {
    "excludedFilePatterns": ["/Ui/"],
    "excludedNamespacePatterns": []
  },
  "methodLength": {
    "maxStatements": 30,
    "maxLines": 40
  }
}
